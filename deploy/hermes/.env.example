# Hermes Gateway environment variables
# Copy this file to .env (same directory) and fill in values.

# API server key — clients authenticate with: Authorization: Bearer <value>
# Must match API_SERVER_KEY in the root .env
API_SERVER_KEY=

# Sales MCP token — used by Hermes to authenticate to the MCP server
# Must match SALES_MCP_TOKEN in the root .env
SALES_MCP_TOKEN=

# (Optional) Override the Hermes port if needed
# PORT=8642

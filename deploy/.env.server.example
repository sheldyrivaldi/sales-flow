# ─────────────────────────────────────────────────────────────────────────────
# Template ENV untuk server. Salin jadi .env.server lalu isi nilainya:
#     cp .env.server.example .env.server
# JANGAN commit .env.server (berisi rahasia). Sudah masuk .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── Aplikasi ────────────────────────────────────────────────────────────────
# Port yang diekspos ke host. Ganti bila 80/8080 sudah dipakai layanan lain.
WEB_PORT=80
API_PORT=8080

# AUTO_MIGRATE=true → api menjalankan migrasi DB saat boot. Aman untuk skema
# yang belum ada; set false bila kamu menjalankan migrasi manual.
AUTO_MIGRATE=true

# ── Database EKSTERNAL (Postgres yang sudah ada) ──────────────────────────────
# WAJIB. Arahkan ke Postgres server. Contoh:
#   postgres://user:pass@10.0.0.5:5432/salespilot?sslmode=disable
# Gunakan host yang bisa dijangkau DARI DALAM container api (IP host / DNS
# internal, bukan "localhost" — localhost di container = container itu sendiri).
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME?sslmode=disable

# ── Hermes EXISTING (dashboard + home dir) ────────────────────────────────────
# 1) Dashboard AI Agent yang sudah berjalan di server. Halaman Setting AI Agent
#    mem-proxy ke sini. Pakai alamat yang bisa dijangkau DARI container api.
HERMES_TUI_BASE_URL=http://192.168.110.100:9119

# 2) INTI AGAR ENGINE JALAN: path folder home Hermes existing di HOST server.
#    Di sinilah login provider (OAuth ChatGPT/Codex) tersimpan. Bridge menumpang
#    folder ini sehingga semua menu AI memakai login itu otomatis.
#    Cari dengan: (jika Hermes non-Docker) `echo $HERMES_HOME` atau `ls -d ~/.hermes`
#                 (jika Hermes Docker)     `docker inspect <hermes> --format '{{json .Mounts}}'`
HERMES_HOME_HOST_PATH=/home/moonlay/.hermes

# 3) Token dashboard. Harus SAMA dengan HERMES_DASHBOARD_SESSION_TOKEN milik
#    Hermes existing bila dashboard-nya dijalankan mode token (--insecure).
#    Bila dashboard existing pakai login form (gated), token ini diabaikan dan
#    kamu login manual di iframe — isi apa saja atau kosongkan.
HERMES_DASHBOARD_SESSION_TOKEN=

# ── Bridge / engine ───────────────────────────────────────────────────────────
# Kunci Bearer antara api dan bridge (bukan ke internet). Bebas, tapi RAHASIA
# dan panjang. Samakan di kedua sisi (dipakai bridge sebagai API_SERVER_KEY).
API_SERVER_KEY=ganti-dengan-string-acak-panjang

# Model utama. Pakai yang tersedia di provider Hermes existing.
HERMES_MODEL=gpt-5.5
# Model cadangan (opsional). Kosongkan bila tidak mau ganti model saat gagal.
HERMES_MODEL_FALLBACKS=
# Batas long task (detik). 600 = 10 menit. Jangan turunkan ke 90.
HERMES_API_CALL_STALE_TIMEOUT=600
# Toolset agent. "web" agar riset internet aktif (dipakai analisa & playbook).
ENABLED_TOOLSETS=web

# Provider key — HANYA jika Hermes existing belum login lewat OAuth device-code.
# Bila sudah login (home dir dishare di atas), dua ini boleh kosong.
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# ── Rahasia aplikasi (WAJIB, buat acak & simpan) ─────────────────────────────
# JWT untuk sesi login user aplikasi.
JWT_SECRET=ganti-dengan-string-acak-panjang
# Kunci workspace Hermes (dipakai chat/learning hook).
WORKSPACE_SESSION_KEY=ganti-dengan-string-acak-panjang
# Token MCP (server MCP aplikasi ini).
SALES_MCP_TOKEN=ganti-dengan-string-acak-panjang
# Secret callback internal (job async playbook & analisa). WAJIB terisi agar
# Hermes bisa melapor balik hasil ke aplikasi.
CRON_TRIGGER_SECRET=ganti-dengan-string-acak-panjang
# Kunci enkripsi konfigurasi AI Provider (opsional; fitur mati bila kosong).
# Harus 32-byte base64. Buat: openssl rand -base64 32
CONFIG_ENC_KEY=

# ── Admin awal (di-seed saat boot pertama) ───────────────────────────────────
SEED_ADMIN_EMAIL=admin@perusahaan.com
SEED_ADMIN_PASSWORD=ganti-dengan-password-kuat

# SalesPilot — Environment Variables
# Copy this file: cp .env.example .env
# Then fill in all empty values before starting the stack.
# NEVER commit the .env file — it is in .gitignore.

# --- Server ---
PORT=8080

# Run pending db/migrations (embedded in the API binary) automatically on
# boot. Set to false only if migrations are deliberately managed out-of-band
# (e.g. a DBA-controlled company database). Default: true.
AUTO_MIGRATE=true

# --- Uploads (EP-13 PDF Ingest) ---
# Directory where uploaded PDFs (Company Profile ingest) are stored.
# In docker-compose this is a named volume mount; for native dev any local
# writable path works.
UPLOAD_DIR=./data/uploads

# --- Database (Docker Compose) ---
# In docker-compose, the API connects to the "postgres" service by hostname.
DATABASE_URL=postgres://salespilot:salespilot@postgres:5432/salespilot?sslmode=disable

# Native dev on Windows (Postgres running locally on port 5433 to avoid conflicts
# with other local Postgres installations; adjust if yours is on a different port):
# DATABASE_URL=postgres://salespilot:salespilot@127.0.0.1:5433/salespilot?sslmode=disable

# --- Postgres service (used by docker-compose postgres service) ---
POSTGRES_USER=salespilot
POSTGRES_PASSWORD=salespilot
POSTGRES_DB=salespilot

# --- Auth ---
# Generate a strong random string (e.g. openssl rand -hex 32)
JWT_SECRET=

# --- AI Provider Config (EP-18 ST-18.4) ---
# Encrypts ai_provider_setting.api_key_encrypted (AES-256-GCM). Must be
# exactly 32 bytes hex-encoded (64 hex chars) — generate with:
#   openssl rand -hex 32
# Optional: without it, the "AI Provider Config from UI" feature is simply
# unavailable (rest of the app is unaffected — PRD §8 non-blocking).
CONFIG_ENC_KEY=

# --- Hermes Bridge ---
# URL ke hermes-bridge service (FastAPI Python yang membungkus Hermes AIAgent).
HERMES_BASE_URL=http://hermes-bridge:8642

# URL ke hermes-tui sidecar (official nousresearch/hermes-agent image
# menjalankan `hermes dashboard` — config/API-key/OAuth/sessions asli
# Hermes lewat web, admin-only). Service TERPISAH dari hermes-bridge di
# atas — tidak ada published host port, hanya diakses dari Go API di
# jaringan compose.
HERMES_TUI_BASE_URL=http://hermes-tui:9119

# How the Hermes cron job's callback reaches this API from inside hermes-tui's
# container (compose-network DNS name, not the host-facing one). Default is
# correct for docker-compose; leave unset otherwise.
INTERNAL_API_BASE_URL=http://api:8080

# API key — hermes-bridge memakai ini untuk auth inbound. Harus sama di semua service.
API_SERVER_KEY=

# Shared secret between api and hermes-tui's dashboard --insecure session-
# token gate. Same value goes to both — hermes-tui reads it directly as its
# own auth token; api sends it as "Authorization: Bearer <value>" when
# calling hermes-tui's /api/cron/jobs REST API (crawl automation upsert).
# Generate with: openssl rand -hex 32
HERMES_DASHBOARD_SESSION_TOKEN=

# Gates POST /internal/discovery/trigger — the callback the upserted Hermes
# cron job hits to ask "run discovery now if due" (EP-12 crawl automation).
# Embedded verbatim into that job's prompt text, so kept separate from
# API_SERVER_KEY. Generate with: openssl rand -hex 32
CRON_TRIGGER_SECRET=

# Single workspace session key — keeps Hermes memory accumulating across sessions
WORKSPACE_SESSION_KEY=

# Model Hermes yang dipakai (lewatkan ke AIAgent constructor).
# Contoh: anthropic/claude-sonnet-4-6 (via OpenRouter) atau gpt-4o (via OpenAI)
HERMES_MODEL=

# Toolset yang diaktifkan (CSV, mis. web,search). Default: web
ENABLED_TOOLSETS=web

# Provider API key (salah satu wajib diisi agar Hermes bisa memanggil model).
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# --- MCP ---
# Bearer token Hermes uses to authenticate to the SalesPilot MCP server (/mcp)
# Must match SALES_MCP_TOKEN in deploy/hermes/.env
SALES_MCP_TOKEN=

# --- Seed ---
# Admin account created on first boot if it doesn't exist
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=

# --- SMTP (undangan event terjadwal) ---
# Opsional: tanpa ini, penjadwalan undangan tetap tercatat tapi pengiriman
# ditandai gagal. Isi dengan relay SMTP milikmu (Gmail, Microsoft 365, relay
# perusahaan). Aplikasi tidak menyimpan kredensial ini — hanya membaca env.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587                 # 587 = STARTTLS, 465 = TLS implisit
# SMTP_USERNAME=
# SMTP_PASSWORD=                # gunakan App Password, bukan password akun
# SMTP_FROM=no-reply@perusahaan.com   # alamat pengirim amplop (akun relay)
# INVITE_TIMEZONE=Asia/Jakarta  # arti "jam 07:00" untuk jadwal non-custom

# --- Hermes image (optional) ---
# Pin to a specific Hermes Agent image tag before going to production.
# Leave empty if running Hermes natively (see README for fallback instructions).
# HERMES_IMAGE=hermes-agent:v0.15.1

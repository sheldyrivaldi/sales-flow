# SalesPilot — Environment Variables
# Copy this file: cp .env.example .env
# Then fill in all empty values before starting the stack.
# NEVER commit the .env file — it is in .gitignore.

# --- Server ---
PORT=8080

# --- Database (Docker Compose) ---
# In docker-compose, the API connects to the "postgres" service by hostname.
DATABASE_URL=postgres://salespilot:salespilot@postgres:5432/salespilot?sslmode=disable

# Native dev on Windows (Postgres running locally on port 5433 to avoid conflicts
# with other local Postgres installations; adjust if yours is on a different port):
# DATABASE_URL=postgres://salespilot:salespilot@127.0.0.1:5433/salespilot?sslmode=disable

# --- Postgres service (used by docker-compose postgres service) ---
POSTGRES_USER=salespilot
POSTGRES_PASSWORD=salespilot
POSTGRES_DB=salespilot

# --- Auth ---
# Generate a strong random string (e.g. openssl rand -hex 32)
JWT_SECRET=

# --- Hermes Bridge ---
# URL ke hermes-bridge service (FastAPI Python yang membungkus Hermes AIAgent).
HERMES_BASE_URL=http://hermes-bridge:8642

# API key — hermes-bridge memakai ini untuk auth inbound. Harus sama di semua service.
API_SERVER_KEY=

# Single workspace session key — keeps Hermes memory accumulating across sessions
WORKSPACE_SESSION_KEY=

# Model Hermes yang dipakai (lewatkan ke AIAgent constructor).
# Contoh: anthropic/claude-sonnet-4-6 (via OpenRouter) atau gpt-4o (via OpenAI)
HERMES_MODEL=

# Toolset yang diaktifkan (CSV, mis. web,search). Default: web
ENABLED_TOOLSETS=web

# Provider API key (salah satu wajib diisi agar Hermes bisa memanggil model).
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# --- MCP ---
# Bearer token Hermes uses to authenticate to the SalesPilot MCP server (/mcp)
# Must match SALES_MCP_TOKEN in deploy/hermes/.env
SALES_MCP_TOKEN=

# --- Seed ---
# Admin account created on first boot if it doesn't exist
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=

# --- Hermes image (optional) ---
# Pin to a specific Hermes Agent image tag before going to production.
# Leave empty if running Hermes natively (see README for fallback instructions).
# HERMES_IMAGE=hermes-agent:v0.15.1
